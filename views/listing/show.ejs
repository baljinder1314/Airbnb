<% layout('/layouts/boilerplate') %>

<body>
  <div class="row mt-3">
    <div class="col-8 offset-md-3 offset-2">
      <h3>Listing Detail:</h3>
    </div>
    <div class="card col-8 col-md-6 offset-2 offset-md-3" >
      <img
        src="<%=listing.image%>"
        class="card-img-top show-image"
        alt="listing_image"
      />
      <div class="card-body">
        <p class="card-text">
          <b> <%=listing?.title%></b> <br />
          <%=listing?.description%> <br />
          &#8377; <%=listing?.price?.toLocaleString('en-IN')%>
          <br />
          <%=listing?.location%> <br />
          <%=listing?.country%>
        </p>
      </div>
    </div>
  </div>
  <div class=" offset-2 offset-md-3   show-btns">
    <a class="btn " href="/listings/<%=listing._id%>/edit">Edit</a>
    <form action="/listings/<%=listing._id%>?_method=DELETE" method="post">
      <button class="btn">Delete</button>
    </form>
  </div>
</body>
