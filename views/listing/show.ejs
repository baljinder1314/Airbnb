<% layout('/layouts/boilerplate') %>

<body>
  <div class="row mt-3">
    <div class="col-8 offset-md-3 offset-2">
      <h2><b> <%=listing?.title%></b></h2>
    </div>
    <div class="card col-8 col-md-6 offset-2 offset-md-3">
      <img
        src="<%=listing.image%>"
        class="card-img-top show-image"
        alt="listing_image"
      />
      <div class="card-body">
        <p class="card-text">
          <%=listing?.description%> <br />
          &#8377; <%=listing?.price?.toLocaleString('en-IN')%>
          <br />
          <%=listing?.location%> <br />
          <%=listing?.country%>
        </p>
      </div>
    </div>
  </div>
  <div class="offset-2 offset-md-3 show-btns">
    <a class="btn" href="/listings/<%=listing._id%>/edit">Edit</a>
    <form action="/listings/<%=listing._id%>?_method=DELETE" method="post">
      <button class="btn">Delete</button>
    </form>
  </div>

  <div class="mt-3 col-8 offset-md-3 offset-2">
    <h3>Leave a Review</h3>
    <form
      action="/listtings/<%= listing._id  %>/review"
      method="post"
      novalidate
      class="needs-validation"
    >
      <div class="">
        <label for="rating" class="form-label">Rating</label>
        <input
          type="range"
          class="form-range"
          min="1"
          max="5"
          name="review[rating]"
          id="rating"
        />
      </div>
      <div class="mb-3">
        <label for="comment" class="form-label">Comment</label>
        <textarea
          required
          type="text"
          class="form-control"
          name="review[comment]"
          id="comment"
        ></textarea>
        <div class="invalid-feedback">Please Add Some Comments for review</div>
      </div>
      <div class="">
        <button class="btn">Submit</button>
      </div>
    </form>
    <hr />

    <div class="">
      <h3>All Reviews</h3>
      <div class="row">
        <% for(let review of listing.reviews){ %>
        <div class="card mb-2 ms-1 col-12 col-md-5 border">
          <div class="card-body">
            <h5 class="card-title">Mannu</h5>
            <p class="card-text"><%= review.comment %></p>
            <div class="card-text">Rating: <%= review.rating %> &#9733;</div>
            <form action="/listings/<%=listing._id%>/review/<%=review._id%>?_method=DELETE" method="post">
              <button class="btn btn-sm mb-3">Delete</button>
            </form>
          </div>

        </div>
          <%}%>
  </div>
</body>
